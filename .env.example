# ───────────── Riot API ─────────────
# Use a PERSONAL key (non-expiring), not the 24h dev key.
# https://developer.riotgames.com/
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Match routing region group (France -> EUROPE) and default platform for new players.
REGION_GROUP=EUROPE
DEFAULT_PLATFORM=euw1

# ───────────── Postgres ─────────────
# The ONLY place the DB credentials live. The worker/CLI build their connection
# string from these, and Metabase reuses POSTGRES_PASSWORD — so there's a single
# password to change. (DATABASE_URL is derived; set it only to point elsewhere.)
POSTGRES_USER=rift
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=lol

# ───────────── Offsite backups (prod only) ─────────────
# Used by the backup service in docker-compose.prod.yml. See README for rclone
# Google Drive setup; the resulting rclone.conf goes next to this file (gitignored).
RCLONE_REMOTE=gdrive
RCLONE_PATH=rift-archive-backups
BACKUP_RETENTION_DAYS=30
# Dump schedule (busybox crontab) and timezone for the backup + autoheal sidecars.
BACKUP_CRON=17 3 * * *
TZ=Europe/Paris
